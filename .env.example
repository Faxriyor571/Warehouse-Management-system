# ============================================================
# Warehouse Management System - Environment variables
# Copy this file to ".env" and adjust the values.
# NEVER commit the real ".env" file to version control.
#
# When APP_ENV=production, the app refuses to start (fails fast) unless
# SECRET_KEY, FIRST_ADMIN_PASSWORD and CORS_ORIGINS are changed from their
# defaults below and DEBUG=false. See app/config.py.
# ============================================================

# --- Application ---
APP_NAME="Ombor Boshqaruv Tizimi"
APP_ENV=development            # development | production
DEBUG=true                      # MUST be false in production
HOST=0.0.0.0
PORT=8000

# --- Database (PostgreSQL) ---
POSTGRES_USER=wms_user
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=wms_db

# --- Security ---
# Generate a strong secret key, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(64))"
# Production example: SECRET_KEY=8k3Jz... (64+ random characters, unique per environment)
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# --- CORS ---
# Comma-separated list of allowed origins. "*" is only accepted in development;
# production requires explicit origins, e.g.:
#   CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=*

# --- Session cookie ---
SESSION_COOKIE_NAME=wms_session
SESSION_COOKIE_SECURE=false     # set true in production (HTTPS)

# --- Uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# --- Default super admin (created on first seed) ---
FIRST_ADMIN_USERNAME=admin
# MUST be changed from this default in production (a strong, unique password).
FIRST_ADMIN_PASSWORD=Admin12345!
FIRST_ADMIN_FULLNAME=Bosh Administrator
